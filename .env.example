# ──────────────────────────────────────────────────────────────
# BINGER — Environment Variables
# Copy to `.env` and fill in values.
# ──────────────────────────────────────────────────────────────

# ── TMDB (server-side only) ───────────────────────────────────
TMDB_API_KEY=

# ── API gateway (public URL as seen by browser / device) ─────
# On iPhone: set both to http://<your-pc-wifi-ip>:8080 (not localhost).
PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# ── JWT auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-use-openssl-rand-base64-32
JWT_ACCESS_TTL_SEC=3600
JWT_REFRESH_TTL_SEC=2592000
MAGIC_LINK_TTL_SEC=900

# Redirect after Google / magic-link login
APP_REDIRECT_URL=binger://auth/callback

# ── Google OAuth (required for Google login) ─────────────────
# Authorized redirect URI in Google Console:
#   {PUBLIC_API_URL}/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SMTP (magic-link emails; if empty, link is printed to API logs) ─
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Binger <noreply@binger.app>

# ── PostgreSQL (Docker service `postgres`) ────────────────────
POSTGRES_DB=binger
POSTGRES_USER=binger_user
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── AI recommendations (batch only; users cannot refresh) ───
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
# Daily batch cron (server TZ). Default: 03:00 Asia/Tehran
AI_RECS_BATCH_CRON=0 3 * * *
AI_RECS_BATCH_TZ=Asia/Tehran
AI_RECS_BATCH_ENABLED=true

# ── Media uploads (local disk or GCS) ─────────────────────────
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:8080/uploads
# GCS (production): STORAGE_DRIVER=gcs, GCS_BUCKET=your-bucket, GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
